# ── Environment ──
# development | staging | production
ENVIRONMENT=development
# json | text (text is human-readable for local dev)
LOG_FORMAT=text

# ── API Keys (required) ──
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here
# NewsAPI (optional but recommended): https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Auth (required) ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=generate_a_long_random_secret_here
# The single email address granted admin privileges
ADMIN_EMAIL=admin@example.com
# Google OAuth Client ID (optional, required if using Google Login)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Database (required) ──
DATABASE_URL=mysql+aiomysql://root:password@localhost/stockanalyst

# ── Redis (optional for dev, required for production) ──
# REDIS_URL=redis://localhost:6379/0

# ── Optional overrides ──
# HOST=127.0.0.1
# PORT=8000
# CORS_ORIGINS=["http://localhost:5173"]
# WORKERS=4
# MAX_CONCURRENT_ANALYSES=10
# MAX_USER_CONCURRENT=2

# ── Observability (optional) ──
# SENTRY_DSN=https://your-key@sentry.io/your-project

# ── Cache TTLs (seconds, optional) ──
# CACHE_TTL_FINANCIAL=900
# CACHE_TTL_NEWS=900
# CACHE_TTL_FILINGS=3600
# CACHE_TTL_PEERS=3600
