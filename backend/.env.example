# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# NewsAPI Key (optional but recommended — primary news source;
# falls back to Google News RSS if missing)
# Get yours at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# JWT signing secret (required)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=generate_a_long_random_secret_here

# Optional overrides
# HOST=127.0.0.1
# PORT=8000
# CORS_ORIGINS=["http://localhost:5173"]
# DATABASE_URL=mysql+aiomysql://root:password@localhost/stockanalyst
